<Window x:Class="Transkript.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transkript"
        Width="380" Height="450"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

  <Window.Resources>

    <Style x:Key="Input" TargetType="TextBox">
      <Setter Property="Background"               Value="#F7F7F7"/>
      <Setter Property="Foreground"               Value="#0D0D0D"/>
      <Setter Property="CaretBrush"               Value="#0D0D0D"/>
      <Setter Property="BorderBrush"              Value="#EBEBEB"/>
      <Setter Property="BorderThickness"          Value="1"/>
      <Setter Property="Height"                   Value="46"/>
      <Setter Property="FontSize"                 Value="14"/>
      <Setter Property="FontFamily"               Value="Segoe UI"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10" ClipToBounds="True">
              <ScrollViewer x:Name="PART_ContentHost" Margin="14,0"
                            VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="border" Property="BorderBrush"     Value="#0D0D0D"/>
                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                <Setter TargetName="border" Property="Background"      Value="#FFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="Pwd" TargetType="PasswordBox">
      <Setter Property="Background"      Value="#F7F7F7"/>
      <Setter Property="Foreground"      Value="#0D0D0D"/>
      <Setter Property="BorderBrush"     Value="#EBEBEB"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Height"          Value="46"/>
      <Setter Property="FontSize"        Value="14"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="PasswordBox">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10" ClipToBounds="True">
              <ScrollViewer x:Name="PART_ContentHost" Margin="14,0,50,0"
                            VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="border" Property="BorderBrush"     Value="#0D0D0D"/>
                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                <Setter TargetName="border" Property="Background"      Value="#FFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background"      Value="#0D0D0D"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Height"          Value="46"/>
      <Setter Property="FontSize"        Value="14"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="10">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bg" Property="Background" Value="#EBEBEB"/>
                <Setter Property="Foreground" Value="#9B9B9B"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnIcon" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"      Value="#C0C0C0"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#0D0D0D"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Window.Effect>
    <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.09" Color="Black"/>
  </Window.Effect>

  <Border x:Name="Root" Background="White" CornerRadius="16"
          BorderBrush="#EBEBEB" BorderThickness="1"
          MouseLeftButtonDown="Root_MouseDown">
    <Grid>

      <Button Style="{StaticResource BtnIcon}"
              Width="28" Height="28" FontSize="12"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,14,14,0"
              Content="✕" Click="BtnClose_Click"/>

      <StackPanel Margin="36,30,36,34">

        <!-- Logo -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,34">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,13">
            <Rectangle Width="3" Height="5"  Fill="#D8D8D8" RadiusX="1.5" RadiusY="1.5" Margin="2,0" VerticalAlignment="Center"/>
            <Rectangle Width="3" Height="10" Fill="#B0B0B0" RadiusX="1.5" RadiusY="1.5" Margin="2,0" VerticalAlignment="Center"/>
            <Rectangle Width="3" Height="17" Fill="#606060" RadiusX="1.5" RadiusY="1.5" Margin="2,0" VerticalAlignment="Center"/>
            <Rectangle Width="3" Height="23" Fill="#0D0D0D" RadiusX="1.5" RadiusY="1.5" Margin="2,0" VerticalAlignment="Center"/>
            <Rectangle Width="3" Height="17" Fill="#606060" RadiusX="1.5" RadiusY="1.5" Margin="2,0" VerticalAlignment="Center"/>
            <Rectangle Width="3" Height="10" Fill="#B0B0B0" RadiusX="1.5" RadiusY="1.5" Margin="2,0" VerticalAlignment="Center"/>
            <Rectangle Width="3" Height="5"  Fill="#D8D8D8" RadiusX="1.5" RadiusY="1.5" Margin="2,0" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="Transkript" FontSize="21" FontWeight="Bold"
                     Foreground="#0D0D0D" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
          <TextBlock Text="Dictée vocale locale" FontSize="12" Foreground="#B0B0B0"
                     HorizontalAlignment="Center" Margin="0,5,0,0" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Email -->
        <TextBlock Text="EMAIL" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"
                   Margin="0,0,0,7" FontFamily="Segoe UI"/>
        <TextBox x:Name="TxtEmail" Style="{StaticResource Input}"
                 Margin="0,0,0,18" KeyDown="Field_KeyDown"/>

        <!-- Password -->
        <TextBlock Text="MOT DE PASSE" Foreground="#B0B0B0" FontSize="10" FontWeight="SemiBold"
                   Margin="0,0,0,7" FontFamily="Segoe UI"/>
        <Grid>
          <PasswordBox x:Name="PwdPassword" Style="{StaticResource Pwd}"
                       KeyDown="Field_KeyDown"/>
          <TextBox x:Name="TxtPwdVisible" Style="{StaticResource Input}"
                   Padding="14,0,50,0" Visibility="Collapsed" KeyDown="Field_KeyDown"/>
          <Button x:Name="BtnEye" Style="{StaticResource BtnIcon}"
                  Width="44" Height="46" FontSize="14"
                  HorizontalAlignment="Right" Content="👁"
                  Click="BtnEye_Click"/>
        </Grid>

        <!-- Error -->
        <TextBlock x:Name="TxtError" Foreground="#E5383B" FontSize="12" TextWrapping="Wrap"
                   Margin="0,12,0,0" Visibility="Collapsed" FontFamily="Segoe UI"/>

        <!-- Submit -->
        <Button x:Name="BtnSubmit" Style="{StaticResource BtnPrimary}"
                Content="Se connecter" Margin="0,22,0,0"
                Click="BtnSubmit_Click"/>

      </StackPanel>
    </Grid>
  </Border>
</Window>
