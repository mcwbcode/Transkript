<Window x:Class="Transkript.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transkript"
        Width="400" Height="420"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

  <Window.Resources>

    <Style x:Key="Input" TargetType="TextBox">
      <Setter Property="Background"              Value="#111111"/>
      <Setter Property="Foreground"              Value="#f0f0f0"/>
      <Setter Property="CaretBrush"              Value="#f0f0f0"/>
      <Setter Property="BorderBrush"             Value="#2e2e2e"/>
      <Setter Property="BorderThickness"         Value="1"/>
      <Setter Property="Height"                  Value="44"/>
      <Setter Property="FontSize"                Value="14"/>
      <Setter Property="FontFamily"              Value="Segoe UI"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8" ClipToBounds="True">
              <ScrollViewer x:Name="PART_ContentHost" Margin="12,0"
                            VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="border" Property="BorderBrush" Value="#e5383b"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="Pwd" TargetType="PasswordBox">
      <Setter Property="Background"      Value="#111111"/>
      <Setter Property="Foreground"      Value="#f0f0f0"/>
      <Setter Property="BorderBrush"     Value="#2e2e2e"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Height"          Value="44"/>
      <Setter Property="FontSize"        Value="14"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="PasswordBox">
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8" ClipToBounds="True">
              <ScrollViewer x:Name="PART_ContentHost" Margin="12,0,44,0"
                            VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsFocused" Value="True">
                <Setter TargetName="border" Property="BorderBrush" Value="#e5383b"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background"   Value="#e5383b"/>
      <Setter Property="Foreground"   Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Height"       Value="44"/>
      <Setter Property="FontSize"     Value="14"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
      <Setter Property="FontFamily"   Value="Segoe UI"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="#c9292c"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bg" Property="Background" Value="#2a1010"/>
                <Setter Property="Foreground" Value="#555"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnIcon" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"      Value="#555"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#ccc"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Window.Effect>
    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.6" Color="Black"/>
  </Window.Effect>

  <Border x:Name="Root" Background="#0d0d0d" CornerRadius="16"
          BorderBrush="#2a2a2a" BorderThickness="1"
          MouseLeftButtonDown="Root_MouseDown">
    <Grid>

      <Button Style="{StaticResource BtnIcon}"
              Width="28" Height="28" FontSize="13"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,12,14,0"
              Content="✕" Click="BtnClose_Click"/>

      <StackPanel Margin="36,24,36,32">

        <!-- Logo -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Ellipse Width="14" Height="14" Fill="#e5383b" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
              <Rectangle Width="3" Height="5"  Fill="#3a3a3a" RadiusX="1" RadiusY="1" Margin="1,0"/>
              <Rectangle Width="3" Height="9"  Fill="#4a4a4a" RadiusX="1" RadiusY="1" Margin="1,0"/>
              <Rectangle Width="3" Height="15" Fill="#666"    RadiusX="1" RadiusY="1" Margin="1,0"/>
              <Rectangle Width="3" Height="20" Fill="#888"    RadiusX="1" RadiusY="1" Margin="1,0"/>
              <Rectangle Width="3" Height="15" Fill="#666"    RadiusX="1" RadiusY="1" Margin="1,0"/>
              <Rectangle Width="3" Height="9"  Fill="#4a4a4a" RadiusX="1" RadiusY="1" Margin="1,0"/>
              <Rectangle Width="3" Height="5"  Fill="#3a3a3a" RadiusX="1" RadiusY="1" Margin="1,0"/>
            </StackPanel>
          </StackPanel>
          <TextBlock Text="Transkript" FontSize="22" FontWeight="Bold"
                     Foreground="#f0f0f0" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
          <TextBlock Text="Dictée vocale locale" FontSize="12" Foreground="#444"
                     HorizontalAlignment="Center" Margin="0,4,0,0" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Email -->
        <TextBlock Text="Email" Foreground="#555" FontSize="11" FontWeight="SemiBold"
                   Margin="0,0,0,6" FontFamily="Segoe UI"/>
        <TextBox x:Name="TxtEmail" Style="{StaticResource Input}"
                 Margin="0,0,0,14" KeyDown="Field_KeyDown"/>

        <!-- Mot de passe -->
        <TextBlock Text="Mot de passe" Foreground="#555" FontSize="11" FontWeight="SemiBold"
                   Margin="0,0,0,6" FontFamily="Segoe UI"/>
        <Grid>
          <PasswordBox x:Name="PwdPassword" Style="{StaticResource Pwd}"
                       KeyDown="Field_KeyDown"/>
          <TextBox x:Name="TxtPwdVisible" Style="{StaticResource Input}"
                   Padding="12,0,44,0" Visibility="Collapsed" KeyDown="Field_KeyDown"/>
          <Button x:Name="BtnEye" Style="{StaticResource BtnIcon}"
                  Width="40" Height="44" FontSize="15"
                  HorizontalAlignment="Right" Content="👁"
                  Click="BtnEye_Click"/>
        </Grid>

        <!-- Erreur -->
        <TextBlock x:Name="TxtError" Foreground="#e5383b" FontSize="12" TextWrapping="Wrap"
                   Margin="0,12,0,0" Visibility="Collapsed" FontFamily="Segoe UI"/>

        <!-- Bouton -->
        <Button x:Name="BtnSubmit" Style="{StaticResource BtnPrimary}"
                Content="Se connecter" Margin="0,18,0,0"
                Click="BtnSubmit_Click"/>

      </StackPanel>
    </Grid>
  </Border>
</Window>
