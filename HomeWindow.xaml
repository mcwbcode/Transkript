<Window x:Class="Transkript.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transkript"
        Width="380" Height="310"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

  <Window.Resources>

    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background"      Value="#0D0D0D"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Height"          Value="44"/>
      <Setter Property="FontSize"        Value="14"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="10">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnSecondary" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="#6B6B6B"/>
      <Setter Property="BorderBrush"     Value="#EBEBEB"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Height"          Value="38"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="10">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#0D0D0D"/>
                <Setter TargetName="bg" Property="BorderBrush" Value="#C0C0C0"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnIcon" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"      Value="#C0C0C0"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#0D0D0D"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Window.Effect>
    <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.09" Color="Black"/>
  </Window.Effect>

  <Border x:Name="Root" Background="White" CornerRadius="16"
          BorderBrush="#EBEBEB" BorderThickness="1"
          MouseLeftButtonDown="Root_MouseDown">
    <Grid>

      <Button Style="{StaticResource BtnIcon}"
              Width="28" Height="28" FontSize="12"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,14,14,0"
              Content="✕" Click="BtnClose_Click"/>

      <StackPanel Margin="32,24,32,28">

        <!-- Logo row -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
            <Rectangle Width="2.5" Height="5"  Fill="#D8D8D8" RadiusX="1" RadiusY="1" Margin="1.5,0" VerticalAlignment="Center"/>
            <Rectangle Width="2.5" Height="9"  Fill="#A0A0A0" RadiusX="1" RadiusY="1" Margin="1.5,0" VerticalAlignment="Center"/>
            <Rectangle Width="2.5" Height="14" Fill="#0D0D0D" RadiusX="1" RadiusY="1" Margin="1.5,0" VerticalAlignment="Center"/>
            <Rectangle Width="2.5" Height="9"  Fill="#A0A0A0" RadiusX="1" RadiusY="1" Margin="1.5,0" VerticalAlignment="Center"/>
            <Rectangle Width="2.5" Height="5"  Fill="#D8D8D8" RadiusX="1" RadiusY="1" Margin="1.5,0" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="Transkript" FontSize="15" FontWeight="Bold"
                     Foreground="#0D0D0D" VerticalAlignment="Center" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Welcome -->
        <TextBlock Text="Bienvenue," FontSize="12" Foreground="#B0B0B0"
                   Margin="0,0,0,2" FontFamily="Segoe UI"/>
        <TextBlock x:Name="TxtEmail" Text="" FontSize="15" FontWeight="SemiBold"
                   Foreground="#0D0D0D" Margin="0,0,0,18"
                   TextTrimming="CharacterEllipsis" FontFamily="Segoe UI"/>

        <!-- Plan badge + status -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
          <Border x:Name="PlanBadge" CornerRadius="999" Padding="10,4" Margin="0,0,10,0">
            <TextBlock x:Name="TxtPlan" FontSize="10" FontWeight="Bold" FontFamily="Segoe UI"/>
          </Border>
          <TextBlock x:Name="TxtStatusMsg" FontSize="13"
                     VerticalAlignment="Center" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Upgrade notice -->
        <Border x:Name="PnlUpgrade"
                Background="#FFF8F8" BorderBrush="#FDDEDE" BorderThickness="1"
                CornerRadius="10" Padding="14,11" Margin="0,0,0,16"
                Visibility="Collapsed">
          <StackPanel>
            <TextBlock Text="Abonnement Pro requis" FontSize="13" FontWeight="Bold"
                       Foreground="#D03030" Margin="0,0,0,3" FontFamily="Segoe UI"/>
            <TextBlock FontSize="12" Foreground="#B06060" TextWrapping="Wrap" FontFamily="Segoe UI">
              Seul le plan <Run FontWeight="Bold" Foreground="#D03030">Pro</Run>
              permet d'utiliser l'application. Rendez-vous sur le site pour souscrire.
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- Launch button -->
        <Button x:Name="BtnLaunch" Style="{StaticResource BtnPrimary}"
                Content="Lancer Transkript  →"
                Margin="0,0,0,10" Visibility="Collapsed"
                Click="BtnLaunch_Click"/>

        <!-- Logout button -->
        <Button x:Name="BtnLogout" Style="{StaticResource BtnSecondary}"
                Content="Se déconnecter"
                Click="BtnLogout_Click"/>

      </StackPanel>
    </Grid>
  </Border>
</Window>
