<Window x:Class="Transkript.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transkript"
        Width="400" Height="320"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

  <Window.Resources>

    <Style x:Key="BtnPrimary" TargetType="Button">
      <Setter Property="Background"      Value="#e5383b"/>
      <Setter Property="Foreground"      Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Height"          Value="44"/>
      <Setter Property="FontSize"        Value="14"/>
      <Setter Property="FontWeight"      Value="SemiBold"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bg" Property="Background" Value="#c9292c"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnSecondary" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="#666"/>
      <Setter Property="BorderBrush"     Value="#2a2a2a"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Height"          Value="38"/>
      <Setter Property="FontSize"        Value="13"/>
      <Setter Property="FontFamily"      Value="Segoe UI"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bg"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#aaa"/>
                <Setter TargetName="bg" Property="BorderBrush" Value="#555"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BtnIcon" TargetType="Button">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground"      Value="#555"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="6">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#ccc"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </Window.Resources>

  <Window.Effect>
    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.6" Color="Black"/>
  </Window.Effect>

  <Border x:Name="Root" Background="#0d0d0d" CornerRadius="16"
          BorderBrush="#2a2a2a" BorderThickness="1"
          MouseLeftButtonDown="Root_MouseDown">
    <Grid>

      <!-- Bouton fermer -->
      <Button Style="{StaticResource BtnIcon}"
              Width="28" Height="28" FontSize="13"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,12,14,0"
              Content="✕" Click="BtnClose_Click"/>

      <StackPanel Margin="36,22,36,28">

        <!-- Logo -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
          <Ellipse Width="11" Height="11" Fill="#e5383b" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBlock Text="Transkript" FontSize="16" FontWeight="Bold"
                     Foreground="#f0f0f0" VerticalAlignment="Center" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Email -->
        <TextBlock Text="Bienvenue," FontSize="12" Foreground="#555"
                   Margin="0,0,0,2" FontFamily="Segoe UI"/>
        <TextBlock x:Name="TxtEmail" Text="" FontSize="15" FontWeight="SemiBold"
                   Foreground="#f0f0f0" Margin="0,0,0,18"
                   TextTrimming="CharacterEllipsis" FontFamily="Segoe UI"/>

        <!-- Badge plan + statut -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
          <Border x:Name="PlanBadge" CornerRadius="999" Padding="8,3" Margin="0,0,10,0">
            <TextBlock x:Name="TxtPlan" FontSize="11" FontWeight="Bold" FontFamily="Segoe UI"/>
          </Border>
          <TextBlock x:Name="TxtStatusMsg" FontSize="13"
                     VerticalAlignment="Center" FontFamily="Segoe UI"/>
        </StackPanel>

        <!-- Avertissement non-pro -->
        <Border x:Name="PnlUpgrade"
                Background="#130808" BorderBrush="#4a1515" BorderThickness="1"
                CornerRadius="8" Padding="14,11" Margin="0,0,0,16"
                Visibility="Collapsed">
          <StackPanel>
            <TextBlock Text="Abonnement Pro requis" FontSize="13" FontWeight="Bold"
                       Foreground="#f87171" Margin="0,0,0,3" FontFamily="Segoe UI"/>
            <TextBlock FontSize="12" Foreground="#904040" TextWrapping="Wrap" FontFamily="Segoe UI">
              Seul le plan <Run FontWeight="Bold" Foreground="#e07070">Pro</Run>
              permet d'utiliser l'application. Rendez-vous sur le site pour souscrire.
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- Bouton Lancer (pro uniquement) -->
        <Button x:Name="BtnLaunch" Style="{StaticResource BtnPrimary}"
                Content="Lancer Transkript  →"
                Margin="0,0,0,10" Visibility="Collapsed"
                Click="BtnLaunch_Click"/>

        <!-- Bouton Déconnexion -->
        <Button x:Name="BtnLogout" Style="{StaticResource BtnSecondary}"
                Content="Se déconnecter"
                Click="BtnLogout_Click"/>

      </StackPanel>
    </Grid>
  </Border>
</Window>
