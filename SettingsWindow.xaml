<Window
    x:Class="Transkript.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Paramètres — Transkript"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    Width="480" Height="580"
    WindowStartupLocation="CenterScreen"
    MouseLeftButtonDown="OnDrag">

    <Border Background="#1C1C1E" CornerRadius="14"
            BorderBrush="#2E2E2E" BorderThickness="1">
        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Fill="#FF3B30" VerticalAlignment="Center"/>
                <TextBlock Text="Paramètres" Foreground="White" FontSize="15" FontWeight="Bold"
                           Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Tab control -->
            <TabControl Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background"   Value="Transparent"/>
                        <Setter Property="Foreground"   Value="#888"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding"      Value="12,6"/>
                        <Setter Property="FontSize"     Value="12"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Background="Transparent"
                                            CornerRadius="6"
                                            Padding="12,6"
                                            Margin="0,0,4,0">
                                        <ContentPresenter ContentSource="Header"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#2C2C2E"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ── TAB 1 : Général ── -->
                <TabItem Header="Général">
                    <StackPanel Margin="0,16,0,0">

                        <!-- Hotkey -->
                        <TextBlock Text="TOUCHE DE DICTÉE"
                                   Foreground="#666" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <Border x:Name="KeyBorder"
                                Background="#111" CornerRadius="8"
                                BorderBrush="#3A3A3C" BorderThickness="1"
                                Height="44" Cursor="Hand"
                                MouseLeftButtonDown="KeyBorder_Click">
                            <Grid>
                                <TextBlock x:Name="TxtKey" Text="Ctrl Droit"
                                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="TxtListening"
                                   Text="⌨  Appuyez sur la touche souhaitée…"
                                   Foreground="#FF9F0A" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"/>

                        <!-- Language -->
                        <TextBlock Text="LANGUE DE TRANSCRIPTION"
                                   Foreground="#666" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,20,0,8"/>
                        <ComboBox x:Name="CmbLanguage"
                                  Height="40" Background="#111"
                                  Foreground="White" BorderBrush="#3A3A3C"
                                  FontSize="13">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="#1C1C1E"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Padding"    Value="10,6"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBoxItem Tag="auto" Content="🌐  Détection automatique"/>
                            <ComboBoxItem Tag="fr"   Content="🇫🇷  Français"/>
                            <ComboBoxItem Tag="en"   Content="🇬🇧  English"/>
                            <ComboBoxItem Tag="es"   Content="🇪🇸  Español"/>
                            <ComboBoxItem Tag="de"   Content="🇩🇪  Deutsch"/>
                            <ComboBoxItem Tag="it"   Content="🇮🇹  Italiano"/>
                            <ComboBoxItem Tag="pt"   Content="🇵🇹  Português"/>
                            <ComboBoxItem Tag="nl"   Content="🇳🇱  Nederlands"/>
                        </ComboBox>

                    </StackPanel>
                </TabItem>

                <!-- ── TAB 2 : Traitement du texte ── -->
                <TabItem Header="Texte">
                    <StackPanel Margin="0,16,0,0">

                        <TextBlock Text="NETTOYAGE AUTOMATIQUE"
                                   Foreground="#666" FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <Border Background="#111" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Supprimer les mots de remplissage"
                                               Foreground="White" FontSize="13"/>
                                    <TextBlock Text="euh, hum, ben, voilà, donc…"
                                               Foreground="#555" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkFillers" Grid.Column="1"
                                          VerticalAlignment="Center" IsChecked="True"/>
                            </Grid>
                        </Border>

                        <Border Background="#111" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Supprimer les répétitions"
                                               Foreground="White" FontSize="13"/>
                                    <TextBlock Text="«je je veux» → «je veux»"
                                               Foreground="#555" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkDuplicates" Grid.Column="1"
                                          VerticalAlignment="Center" IsChecked="True"/>
                            </Grid>
                        </Border>

                        <Border Background="#111" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Majuscule automatique"
                                               Foreground="White" FontSize="13"/>
                                    <TextBlock Text="Capitalise la première lettre"
                                               Foreground="#555" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkCapitalize" Grid.Column="1"
                                          VerticalAlignment="Center" IsChecked="True"/>
                            </Grid>
                        </Border>

                        <Border Background="#111" CornerRadius="8" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Sauvegarder l'historique"
                                               Foreground="White" FontSize="13"/>
                                    <TextBlock Text="Enregistre chaque dictée localement"
                                               Foreground="#555" FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkHistory" Grid.Column="1"
                                          VerticalAlignment="Center" IsChecked="True"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </TabItem>

                <!-- ── TAB 3 : Dictionnaire personnel ── -->
                <TabItem Header="Dictionnaire">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Remplacez automatiquement des mots ou expressions après la transcription."
                                   Foreground="#888" FontSize="11" TextWrapping="Wrap"/>

                        <!-- List -->
                        <Border Grid.Row="2" Background="#111" CornerRadius="8"
                                BorderBrush="#2C2C2E" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="DictPanel" Margin="8"/>
                            </ScrollViewer>
                        </Border>

                        <!-- Add row -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtDictFrom" Grid.Column="0"
                                     Height="34" Background="#111" Foreground="White"
                                     BorderBrush="#3A3A3C" BorderThickness="1"
                                     Padding="8,0" FontSize="12"
                                     VerticalContentAlignment="Center"/>
                            <TextBox x:Name="TxtDictTo" Grid.Column="2"
                                     Height="34" Background="#111" Foreground="White"
                                     BorderBrush="#3A3A3C" BorderThickness="1"
                                     Padding="8,0" FontSize="12"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="4" Content="+"
                                    Width="34" Height="34"
                                    Click="BtnAddDict_Click"
                                    Background="#0A84FF" Foreground="White"
                                    BorderThickness="0" FontSize="18" FontWeight="Bold">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- Bottom buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Content="Annuler"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Click="BtnCancel_Click"
                        Background="#2C2C2E" Foreground="#AAA"
                        BorderBrush="#3A3A3C" BorderThickness="1">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnSave" Content="Enregistrer"
                        Width="110" Height="34"
                        Click="BtnSave_Click"
                        Background="#0A84FF" Foreground="White"
                        BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
